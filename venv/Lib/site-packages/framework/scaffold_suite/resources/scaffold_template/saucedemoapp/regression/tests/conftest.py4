import subprocess
import sys
from pathlib import Path



# Ensure project root (the directory containing 'apps') is on sys.path so top-level package `apps` is importable
_this = Path(__file__).resolve()
project_root = None

# Prefer a parent that contains both 'apps' and 'README.md' for accuracy
for p in [*_this.parents, _this]:
    if (p / "apps").exists() and (p / "README.md").exists():
        project_root = p
        break

# Fallback: first parent that contains 'apps'
if project_root is None:
    for p in _this.parents:
        if (p / "apps").exists():
            project_root = p
            break

# Final fallback: use a reasonable ancestor if heuristics fail
if project_root is None:
    try:
        project_root = _this.parents[4]
    except Exception:
        project_root = _this.parent

if str(project_root) not in sys.path:
    sys.path.insert(0, str(project_root))
